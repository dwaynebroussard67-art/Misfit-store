# Supabase (same as main site)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Stripe (get from dashboard: Settings → API Keys)
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Notifications (ntfy.sh topic)
NTFY_TOPIC=misfit-store-orders

# Store URL (for main site to link to storefront)
VITE_STORE_URL=https://misfit-store-[deployment].vercel.app

# Base URL used to build Stripe success/cancel redirect links.
# Falls back to https://$VERCEL_URL if unset, but set this explicitly for a
# stable custom domain.
PUBLIC_BASE_URL=https://misfit-store-[deployment].vercel.app

# Legacy local admin password gate (src/lib/store.ts / Admin.tsx).
# Falls back to the hardcoded default "armory-local" if unset — set this
# in production or that default password will grant admin access.
VITE_ADMIN_PASSWORD=

# Optional: Printify integration
PRINTIFY_API_KEY=
